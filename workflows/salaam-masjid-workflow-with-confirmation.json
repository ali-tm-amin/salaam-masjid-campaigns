      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst body = item.body || item;\n\n// Extract form fields\nconst fullName = (body.fullName || body['Full Name'] || '').trim();\nconst email = (body.email || body['Email Address'] || '').trim();\nconst phone = (body.phone || body['Phone Number'] || '').trim();\nconst goalAmt = parseFloat(body.goalAmt || body['Your Fundraising Goal (GBP)']) || 500;\n\n// Generate unique ID for tracking\nconst uniqueId = `SM${Date.now()}${Math.random().toString(36).substr(2, 5).toUpperCase()}`;\n\n// Process name\nconst firstName = fullName.split(' ')[0] || fullName;\n\n// Format currency\nconst fmtGBP = (n) => new Intl.NumberFormat('en-GB', { \n  style: 'currency', \n  currency: 'GBP', \n  minimumFractionDigits: 0 \n}).format(n);\n\n// Campaign URL\nconst campaignUrl = 'https://www.launchgood.com/create#!/create/new/basics?raising_for=community&community_id=21505';\n\n// Completion URL\nconst completionUrl = `https://masjidsalaam.netlify.app/campaign-complete.html?email=${encodeURIComponent(email)}`;\n\n// Timestamp\nconst now = new Date().toLocaleString('en-GB', { timeZone: 'Europe/London' });\n\nreturn [{ \n  json: { \n    uniqueId,\n    fullName, \n    firstName, \n    email, \n    phone,\n    goalAmt, \n    goalFmt: fmtGBP(goalAmt), \n    campaignUrl,\n    completionUrl, \n    submittedAt: now,\n    status: 'Pending'\n  } \n}];"
      },
